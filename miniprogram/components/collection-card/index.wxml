<view class="collection-card pressable fade-in-up" style="animation-delay: {{index * 0.06}}s" bindtap="onTap" bindlongpress="onLongPress">
  <!-- Outer shell — warm tinted card -->
  <view class="card-shell">
    <!-- Cover -->
    <view class="card-cover">
      <image
        src="{{displayCover}}"
        mode="aspectFill"
        class="cover-image"
        lazy-load="{{true}}"
      />
      <!-- Gradient overlay -->
      <view class="cover-overlay"></view>
      <!-- Status badge -->
      <view wx:if="{{showStatus && item.status === 'visited'}}" class="status-badge">
        <lucide-icon name="check" size="20" color="#fff" /> 去过
      </view>
    </view>

    <!-- Card body -->
    <view class="card-body">
      <view class="card-title ellipsis">{{item.title || '未命名地点'}}</view>

      <view class="card-meta">
        <view class="category-tag tag tag-primary">
          <lucide-icon name="{{categoryInfo.icon || 'tag'}}" size="24" />
          <text>{{categoryInfo.label}}</text>
        </view>
        <view wx:if="{{item.rating > 0}}" class="rating">
          <text wx:for="{{[1,2,3,4,5]}}" wx:for-item="s" wx:key="*this"
                class="rating-star {{index < item.rating ? 'active' : ''}}">★</text>
        </view>
      </view>

      <view wx:if="{{displayTags.length > 0}}" class="card-tags">
        <text wx:for="{{displayTags}}" wx:key="*this" class="card-tag-chip" data-tag="{{item}}" catchtap="onTagTap">#{{item}}</text>
        <text wx:if="{{overflowCount > 0}}" class="card-tag-overflow">+{{overflowCount}}</text>
      </view>

      <view wx:if="{{item.location && item.location.name}}" class="card-location ellipsis">
        <lucide-icon name="map-pin" size="24" /> {{item.location.name}}
      </view>

      <view class="card-footer">
        <text class="card-date">{{formattedDate}}</text>
      </view>
    </view>
  </view>
</view>
