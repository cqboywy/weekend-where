.collection-card {
  margin: 8rpx 20rpx;
  border-radius: var(--radius-lg);
  background: var(--color-white);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeInUp 0.4s ease-out both;
}
.collection-card:active {
  transform: scale(0.98);
}

.card-cover {
  position: relative;
  width: 100%;
  height: 420rpx;
  overflow: hidden;
}
.cover-image {
  width: 100%;
  height: 100%;
}

/* Badges */
.platform-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--text-xs);
  color: #fff;
  font-weight: 600;
  line-height: 1.5;
  backdrop-filter: blur(4px);
}
.status-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--text-xs);
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-weight: 500;
  line-height: 1.5;
}

/* Body */
.card-body {
  padding: 20rpx;
}
.card-title {
  font-size: var(--text-md);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 10rpx;
  line-height: var(--leading-tight);
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.rating {
  font-size: var(--text-sm);
  letter-spacing: 2rpx;
}
.card-location {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  line-height: 1.4;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  line-height: 1.4;
}
.card-date {
  color: var(--color-text-tertiary);
}
.card-note {
  max-width: 60%;
  text-align: right;
  color: var(--color-text-secondary);
}
