.collection-card {
  margin: 12rpx 0;
  border-radius: var(--radius-lg);
  background: var(--color-white);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: transform 0.5s ease, box-shadow 0.5s ease;
  animation: fadeInUp 0.6s ease-out both;
}
.collection-card:active { transform: scale(0.98); }

/* Cover — arch shape on top */
.card-cover {
  position: relative;
  width: 100%;
  height: 440rpx;
  overflow: hidden;
  border-radius: var(--radius-arch) var(--radius-arch) 0 0;
}
.cover-image { width: 100%; height: 100%; transition: transform 0.7s ease; }
.collection-card:active .cover-image { transform: scale(1.03); }

/* Badges */
.platform-badge {
  position: absolute; top: 20rpx; left: 20rpx;
  padding: 8rpx 18rpx; border-radius: var(--radius-full);
  font-size: var(--text-xs); color: #fff; font-weight: 600;
}
.status-badge {
  position: absolute; top: 20rpx; right: 20rpx;
  padding: 8rpx 18rpx; border-radius: var(--radius-full);
  font-size: var(--text-xs); background: rgba(45,58,49,0.6); color: #fff;
}

/* Body */
.card-body { padding: 24rpx; }
.card-title {
  font-family: var(--font-heading);
  font-size: var(--text-lg); font-weight: 700;
  color: var(--color-text); margin-bottom: 10rpx;
  line-height: var(--leading-tight);
}
.card-meta { display: flex; align-items: center; gap: 10rpx; margin-bottom: 8rpx; }
.rating { font-size: var(--text-sm); letter-spacing: 2rpx; }
.card-location {
  font-size: var(--text-sm); color: var(--color-primary); margin-bottom: 8rpx;
}
.card-footer {
  display: flex; align-items: center; justify-content: space-between;
  font-size: var(--text-xs); color: #A8A39A;
}
.card-date { color: #A8A39A; }
.card-note { max-width: 60%; text-align: right; }
