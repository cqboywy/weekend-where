/* =============================================
   Collection Card — Editorial Journal v6
   ============================================= */

.collection-card {
  margin: 20rpx 0;
}

/* Outer shell */
.card-shell {
  border-radius: var(--radius-lg);
  background: var(--color-white);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: transform 0.25s cubic-bezier(0.32, 0.72, 0, 1),
              box-shadow 0.3s ease;
}
.collection-card:active .card-shell {
  transform: scale(0.975);
  box-shadow: var(--shadow-float);
}

/* Cover — generous arch top */
.card-cover {
  position: relative;
  width: 100%;
  height: 400rpx;
  overflow: hidden;
}
.cover-image {
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1);
}
.collection-card:active .cover-image {
  transform: scale(1.05);
}

/* Subtle gradient at bottom of cover */
.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(61,43,31,0.15), transparent);
  pointer-events: none;
}

/* Badges */
.platform-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  color: #fff;
  font-weight: 600;
  letter-spacing: var(--tracking-wide);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}
.status-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  background: rgba(61,43,31,0.55);
  color: #fff;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  backdrop-filter: blur(8px);
}

/* Body */
.card-body {
  padding: 24rpx 28rpx 28rpx;
}
.card-title {
  font-family: var(--font-heading);
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
  line-height: var(--leading-tight);
}

/* Meta row — category tag + rating */
.card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}
.category-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
  background: var(--color-primary-soft);
  color: var(--color-primary);
  letter-spacing: var(--tracking-wide);
}
.rating {
  display: flex;
  gap: 2rpx;
  font-size: 28rpx;
}
.rating-star {
  color: var(--color-border);
  transition: color 0.3s ease;
}
.rating-star.active {
  color: #F0A050;
}

/* Card tags */
.card-tags {
  display: flex; align-items: center; gap: 8rpx; flex-wrap: wrap;
  margin-bottom: 10rpx;
}
.card-tag-chip {
  font-size: var(--text-xs); color: var(--color-primary);
  background: var(--color-primary-soft); padding: 4rpx 14rpx;
  border-radius: var(--radius-full); font-weight: 600;
  letter-spacing: 0.5rpx;
}
.card-tag-overflow {
  font-size: var(--text-xs); color: var(--color-muted); font-weight: 600;
}

/* Location */
.card-location {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--text-sm);
  color: var(--color-muted);
  margin-bottom: 12rpx;
}

/* Footer */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--text-xs);
  color: var(--color-muted);
}
.card-date {
  opacity: 0.7;
}
