.collection-card {
  margin: 16rpx;
  transition: transform 0.2s;
}
.collection-card:active {
  transform: scale(0.98);
}

.card-cover {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}
.cover-image {
  width: 100%;
  height: 100%;
}
.platform-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
  line-height: 1.4;
}
.status-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  line-height: 1.4;
}

.card-body {
  padding: 20rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.rating {
  font-size: 24rpx;
}
.card-location {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-bottom: 8rpx;
  line-height: 1.4;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-light);
  line-height: 1.4;
}
.card-date {
  color: #ADB5BD;
}
.card-note {
  max-width: 60%;
  text-align: right;
}
