.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 100rpx 60rpx; }
.empty-icon { margin-bottom: 24rpx; opacity: 0.6; }
.empty-title { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; margin-bottom: 12rpx; }
.empty-desc { font-size: var(--text-base); color: var(--color-primary); text-align: center; margin-bottom: 40rpx; }
.empty-btn { background: var(--color-primary); color: #fff; border-radius: var(--radius-full); padding: 18rpx 60rpx; font-size: var(--text-base); font-weight: 600; letter-spacing: var(--tracking-wide); text-transform: uppercase; border: none; transition: opacity 0.3s ease; }
.empty-btn:active { opacity: 0.8; }
