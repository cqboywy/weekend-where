.list-page { background: var(--color-bg); min-height: 100vh; }

/* Header */
.list-header { padding: 28rpx 24rpx 0; }
.list-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.list-title { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 700; }
.list-search-btn { padding: 8rpx; }

/* Search */
.search-row { display: flex; align-items: center; gap: 12rpx; padding: 0 24rpx 16rpx; animation: fadeInUp 0.3s ease-out; }
.search-input { flex: 1; background: var(--color-surface); border-radius: var(--radius-full); padding: 18rpx 28rpx; font-size: var(--text-base); height: 80rpx; box-sizing: border-box; }
.search-cancel { font-size: var(--text-base); color: var(--color-primary); font-weight: 600; }

/* Category filter */
.category-scroll { padding: 8rpx 24rpx 16rpx; white-space: nowrap; }
.filter-chip {
  display: inline-block; padding: 12rpx 28rpx; border-radius: var(--radius-full);
  font-size: var(--text-sm); background: var(--color-white); color: var(--color-muted);
  margin-right: 12rpx; font-weight: 500;
  border: 1rpx solid var(--color-border);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.filter-chip.active {
  background: var(--color-primary); color: #fff;
  border-color: var(--color-primary); font-weight: 600;
  box-shadow: var(--shadow-button);
}

/* List body */
.list-body { padding: 8rpx 24rpx 48rpx; }
.loading-more { padding: 16rpx; }
.no-more { text-align: center; padding: 48rpx; font-size: var(--text-sm); color: var(--color-muted); font-style: italic; }

/* Action Sheet */
.action-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(61,43,31,0.30); z-index: 1000; display: flex; align-items: flex-end; }
.action-sheet { width: 100%; background: var(--color-white); border-radius: var(--radius-xl) var(--radius-xl) 0 0; padding: 8rpx 16rpx 16rpx; animation: fadeInUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1); }
.action-item { padding: 28rpx; text-align: center; font-size: var(--text-base); color: var(--color-text); border-bottom: 1rpx solid var(--color-border); }
.action-item:last-child { border-bottom: none; }
.action-danger { color: #D4735E; font-weight: 600; }
.action-cancel { padding: 28rpx; text-align: center; font-size: var(--text-base); color: var(--color-primary); margin-top: 8rpx; background: var(--color-surface); border-radius: var(--radius-md); font-weight: 600; }
