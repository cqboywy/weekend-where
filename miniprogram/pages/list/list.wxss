.list-page { background: var(--color-bg); min-height: 100vh; }

/* Header */
.list-header { padding: 24rpx 24rpx 0; }
.list-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.list-title { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 700; }
.list-search-btn { font-size: 40rpx; padding: 8rpx; }

/* Search */
.search-row { display: flex; align-items: center; gap: 12rpx; padding: 0 24rpx 16rpx; }
.search-input { flex: 1; background: var(--color-surface); border-radius: var(--radius-full); padding: 16rpx 28rpx; font-size: var(--text-base); }
.search-cancel { font-size: var(--text-base); color: var(--color-accent); font-weight: 600; }

/* Category filter */
.category-scroll { padding: 8rpx 24rpx 16rpx; white-space: nowrap; }
.filter-chip {
  display: inline-block; padding: 10rpx 24rpx; border-radius: var(--radius-full);
  font-size: var(--text-sm); background: var(--color-white); color: var(--color-primary);
  margin-right: 10rpx; font-weight: 500;
  transition: all 0.3s ease; border: 1rpx solid var(--color-border);
}
.filter-chip:active { transform: scale(0.95); }
.filter-chip.active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); font-weight: 600; }

/* List body */
.list-body { padding: 16rpx 24rpx 40rpx; }
.loading-more { padding: 16rpx; }
.no-more { text-align: center; padding: 48rpx; font-size: var(--text-sm); color: #A8A39A; font-style: italic; }

/* Action Sheet */
.action-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(45,58,49,0.3); z-index: 1000; display: flex; align-items: flex-end; }
.action-sheet { width: 100%; background: var(--color-white); border-radius: var(--radius-xl) var(--radius-xl) 0 0; padding: 8rpx 16rpx 16rpx; animation: fadeInUp 0.5s ease-out; }
.action-item { padding: 28rpx; text-align: center; font-size: var(--text-base); color: var(--color-text); border-bottom: 1rpx solid var(--color-border); }
.action-item:last-child { border-bottom: none; }
.action-danger { color: #B8442A; font-weight: 600; }
.action-cancel { padding: 28rpx; text-align: center; font-size: var(--text-base); color: var(--color-primary); margin-top: 8rpx; background: var(--color-surface); border-radius: var(--radius-md); font-weight: 500; }
