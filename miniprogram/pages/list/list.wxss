.list-page { background: var(--color-bg); min-height: 100vh; }

/* Header */
.list-header { padding: 24rpx 24rpx 0; background: var(--color-white); }
.list-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.list-title { font-size: var(--text-2xl); font-weight: 700; color: var(--color-text); }
.list-search-btn { font-size: 40rpx; padding: 8rpx; }

/* Search bar */
.search-row { display: flex; align-items: center; gap: 12rpx; padding: 0 24rpx 16rpx; background: var(--color-white); }
.search-input { flex: 1; background: var(--color-surface); border-radius: var(--radius-full); padding: 14rpx 24rpx; font-size: var(--text-base); }
.search-cancel { font-size: var(--text-base); color: var(--color-primary); font-weight: 500; }

/* Category filter */
.category-scroll { padding: 8rpx 24rpx 16rpx; background: var(--color-white); white-space: nowrap; border-bottom: 1rpx solid var(--color-border); }
.filter-chip {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  background: var(--color-surface);
  color: var(--color-text-secondary);
  margin-right: 10rpx;
  font-weight: 500;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.filter-chip:active { transform: scale(0.95); }
.filter-chip.active { background: var(--color-primary); color: #fff; font-weight: 600; }

/* Cards area */
.list-body { padding: 16rpx 0 40rpx; }

/* Loading / empty */
.loading-more { padding: 16rpx; }
.no-more { text-align: center; padding: 40rpx; font-size: var(--text-sm); color: var(--color-text-tertiary); }

/* Action Sheet */
.action-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 1000; display: flex; align-items: flex-end; }
.action-sheet { width: 100%; background: var(--color-white); border-radius: var(--radius-xl) var(--radius-xl) 0 0; padding: 8rpx 16rpx 16rpx; animation: slideUp 0.25s ease-out; }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.action-item { padding: 28rpx; text-align: center; font-size: var(--text-base); color: var(--color-text); border-bottom: 1rpx solid var(--color-border); }
.action-item:last-child { border-bottom: none; }
.action-danger { color: var(--color-danger); font-weight: 600; }
.action-cancel { padding: 28rpx; text-align: center; font-size: var(--text-base); color: var(--color-text-secondary); margin-top: 8rpx; background: var(--color-surface); border-radius: var(--radius-md); font-weight: 500; }
