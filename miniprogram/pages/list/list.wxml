<view class="page list-page">
  <view class="list-header">
    <view class="list-title-row">
      <view class="list-title">我的收藏</view>
      <view class="list-search-btn pressable" bindtap="onToggleSearch"><lucide-icon name="search" size="40" color="#E8876A" /></view>
    </view>
    <view wx:if="{{activeStatus}}" class="status-filter-hint">
      <text>筛选：{{activeStatus === 'want_to_go' ? '想去' : '去过'}}</text>
      <text class="clear-filter" bindtap="onClearStatus">✕ 清除</text>
    </view>
  </view>

  <view wx:if="{{showSearch}}" class="search-row">
    <input class="search-input" placeholder="搜索名称或标签" value="{{searchValue}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" focus="{{true}}" confirm-type="search"/>
    <view class="search-cancel" bindtap="onToggleSearch">取消</view>
  </view>

  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view wx:for="{{categories}}" wx:key="key" class="filter-chip pressable {{activeCategory === item.key ? 'active' : ''}}" data-category="{{item.key}}" bindtap="onSelectCategory">{{item.label}}</view>
  </scroll-view>

  <view wx:if="{{tagStats.length > 0 && !activeCategory && !keyword}}" class="tag-stats-row">
    <text class="tag-stats-label">热门标签</text>
    <scroll-view class="tag-stats-scroll" scroll-x enable-flex>
      <view wx:for="{{tagStats}}" wx:key="tag" class="tag-chip pressable" data-tag="{{item.tag}}" bindtap="onTapTag">{{item.tag}}<text class="tag-chip-count"> {{item.count}}</text></view>
    </scroll-view>
  </view>

  <view wx:if="{{!loading && items.length === 0}}" class="list-body">
    <empty-state title="还没有收藏" description="{{activeCategory ? '该分类下暂无收藏' : '去添加你的第一个好吃好玩的地方吧'}}" bind:action="onGoAdd"/>
  </view>

  <view wx:else class="list-body">
    <collection-card wx:for="{{items}}" wx:key="_id" item="{{item}}" index="{{index}}" bind:tap="onCardTap" bind:longpress="onCardLongPress" bind:tagtap="onCardTagTap"/>
    <view wx:if="{{loading}}" class="loading-more"><skeleton loading="{{true}}" count="{{2}}"/></view>
    <view wx:elif="{{!hasMore && items.length > 0}}" class="no-more">— 已经到底了 —</view>
  </view>

  <view wx:if="{{showActionSheet}}" class="action-overlay" bindtap="onCloseAction">
    <view class="action-sheet" catchtap="noop">
      <view class="action-item" data-action="toggleStatus" catchtap="onAction">{{actionItem.status === 'want_to_go' ? '标记为去过' : '标记为想去'}}</view>
      <view class="action-item" data-action="share" catchtap="onAction">分享给好友</view>
      <view class="action-item action-danger" data-action="delete" catchtap="onAction">删除收藏</view>
      <view class="action-cancel" catchtap="onCloseAction">取消</view>
    </view>
  </view>
</view>
