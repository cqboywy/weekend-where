<view class="page list-page">
  <view class="list-header">
    <view class="list-title-row">
      <view wx:if="{{activeStatus}}" class="status-filter-hint">
        <text>{{activeStatus === 'want_to_go' ? '想去' : '去过'}}</text>
        <text class="clear-filter" bindtap="onClearStatus">✕ 清除</text>
      </view>
      <view wx:else class="list-header-label">我的收藏</view>
      <view class="list-search-btn pressable" bindtap="onToggleSearch"><lucide-icon name="search" size="40" color="#9E9688" /></view>
    </view>
  </view>

  <view wx:if="{{showSearch}}" class="search-row">
    <input class="search-input" placeholder="搜索名称、标签、备注或地点" value="{{searchValue}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" focus="{{true}}" confirm-type="search"/>
    <view class="search-cancel" bindtap="onToggleSearch">取消</view>
  </view>

  <!-- Category tabs -->
  <scroll-view class="category-scroll" scroll-x enable-flex enhanced show-scrollbar="{{false}}">
    <view wx:for="{{categories}}" wx:key="key" class="filter-chip pressable {{activeCategory === item.key ? 'active' : ''}}" data-category="{{item.key}}" data-index="{{index}}" bindtap="onSelectCategory">{{item.label}}</view>
  </scroll-view>

  <!-- Swipeable content -->
  <swiper class="list-swiper" current="{{swiperIndex}}" bindchange="onSwiperChange" duration="250" style="height:{{swiperHeight}}px;">
    <swiper-item wx:for="{{categories}}" wx:key="key">
      <scroll-view class="swiper-scroll" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled bindrefresherrefresh="onPullDownRefresh">
        <view wx:if="{{categoryData[item.key].loading}}" class="list-body">
          <skeleton loading="{{true}}" count="{{4}}"/>
        </view>
        <view wx:elif="{{categoryData[item.key].items.length === 0}}" class="list-body">
          <empty-state title="还没有收藏" description="{{item.key ? '该分类下暂无收藏' : '去添加你的第一个好吃好玩的地方吧'}}" bind:action="onGoAdd"/>
        </view>
        <view wx:else class="list-body">
          <collection-card wx:for="{{categoryData[item.key].items}}" wx:for-item="card" wx:key="_id" item="{{card}}" index="{{index}}" bind:tap="onCardTap" bind:longpress="onCardLongPress" bind:tagtap="onCardTagTap"/>
          <view wx:if="{{categoryData[item.key].loadingMore}}" class="loading-more"><skeleton loading="{{true}}" count="{{2}}"/></view>
          <view wx:elif="{{!categoryData[item.key].hasMore && categoryData[item.key].items.length > 0}}" class="no-more">— 已经到底了 —</view>
        </view>
      </scroll-view>
    </swiper-item>
  </swiper>

  <view wx:if="{{showActionSheet}}" class="action-overlay" bindtap="onCloseAction">
    <view class="action-sheet" catchtap="noop">
      <view class="action-item" data-action="toggleNextGo" catchtap="onAction">{{actionItem.nextGo ? '移出下次去' : '加入下次去'}}</view>
      <view class="action-item" data-action="toggleStatus" catchtap="onAction">{{actionItem.status === 'want_to_go' ? '标记为去过' : '标记为想去'}}</view>
      <view class="action-item" data-action="share" catchtap="onAction">分享给好友</view>
      <view class="action-item action-danger" data-action="delete" catchtap="onAction">删除收藏</view>
      <view class="action-cancel" catchtap="onCloseAction">取消</view>
    </view>
  </view>
</view>
