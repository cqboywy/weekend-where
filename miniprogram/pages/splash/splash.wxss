.splash-page {
  position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
  display: flex; align-items: center; justify-content: center;
  z-index: 9999; opacity: 0;
  transition: opacity 0.7s cubic-bezier(0.32, 0.72, 0, 1);
}
.splash-page.show { opacity: 1; }

.splash-content {
  display: flex; flex-direction: column; align-items: center;
  gap: 24rpx;
}

/* Typography */
.splash-cn {
  font-family: "Playfair Display", "Georgia", serif;
  font-size: 96rpx; font-weight: 700;
  letter-spacing: 4rpx; line-height: 1.1;
}
.splash-en {
  font-family: "Source Sans 3", "PingFang SC", sans-serif;
  font-size: 28rpx; font-weight: 600;
  letter-spacing: 8rpx; opacity: 0.55;
  text-transform: uppercase;
}
.splash-tagline {
  font-family: "Source Sans 3", "PingFang SC", sans-serif;
  font-size: 32rpx; font-weight: 500;
  margin-top: 28rpx; opacity: 0.75;
  font-style: italic; letter-spacing: 2rpx;
}

/* Season symbols container */
.splash-symbol {
  width: 240rpx; height: 240rpx;
  display: flex; align-items: center; justify-content: center;
  margin: 16rpx 0;
  animation: symbolFloat 3s ease-in-out infinite;
}
@keyframes symbolFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* ============ Cherry blossom (5 petals) ============ */
.cherry-blossom { position: relative; width: 160rpx; height: 160rpx; }
.petal {
  position: absolute; width: 48rpx; height: 56rpx; border-radius: 48rpx 48rpx 0 0;
  top: 20rpx; left: 56rpx; transform-origin: center 80rpx; opacity: 0.8;
}
.p1 { transform: rotate(0deg); }
.p2 { transform: rotate(72deg); }
.p3 { transform: rotate(144deg); }
.p4 { transform: rotate(216deg); }
.p5 { transform: rotate(288deg); }
.petal-center {
  position: absolute; width: 28rpx; height: 28rpx; border-radius: 50%;
  top: 66rpx; left: 66rpx;
  animation: petalPulse 2s ease-in-out infinite;
}
@keyframes petalPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

/* ============ Summer waves ============ */
.waves { position: relative; width: 180rpx; height: 180rpx; }
.wave {
  position: absolute; width: 80rpx; height: 80rpx;
  border: 6rpx solid; border-radius: 40%; border-color: transparent;
  border-top-color: inherit;
  animation: waveSpin 4s linear infinite;
}
.w1 { top: 50rpx; left: 50rpx; width: 80rpx; height: 80rpx; }
.w2 { top: 35rpx; left: 35rpx; width: 110rpx; height: 110rpx; animation-duration: 5s; animation-direction: reverse; }
.w3 { top: 20rpx; left: 20rpx; width: 140rpx; height: 140rpx; animation-duration: 6s; }
@keyframes waveSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ============ Autumn leaves ============ */
.leaves { position: relative; width: 180rpx; height: 180rpx; }
.leaf {
  position: absolute; width: 36rpx; height: 64rpx;
  border-radius: 50% 0 50% 0; opacity: 0.75;
  animation: leafDrift 2.5s ease-in-out infinite;
}
.l1 { top: 58rpx; left: 72rpx; transform: rotate(0deg); }
.l2 { top: 70rpx; left: 48rpx; transform: rotate(120deg); animation-delay: 0.6s; }
.l3 { top: 70rpx; left: 96rpx; transform: rotate(240deg); animation-delay: 1.2s; }
@keyframes leafDrift {
  0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); }
  50% { transform: translateY(-16rpx) rotate(var(--r, 0deg)); }
}

/* ============ Winter snowflake ============ */
.snowflake { position: relative; width: 180rpx; height: 180rpx; }
.star-bar {
  position: absolute; width: 8rpx; height: 80rpx; border-radius: 4rpx;
  top: 50rpx; left: 86rpx; transform-origin: center 40rpx;
  animation: starPulse 2s ease-in-out infinite;
}
.sb1 { transform: rotate(0deg); }
.sb2 { transform: rotate(60deg); animation-delay: 0.3s; }
.sb3 { transform: rotate(120deg); animation-delay: 0.6s; }
@keyframes starPulse {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}
