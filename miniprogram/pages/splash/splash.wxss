.splash-page {
  position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
  display: flex; align-items: center; justify-content: center;
  z-index: 9999; opacity: 0;
  transition: opacity 0.7s cubic-bezier(0.32, 0.72, 0, 1);
}
.splash-page.show { opacity: 1; }

.splash-content {
  display: flex; flex-direction: column; align-items: center;
  gap: 16rpx;
}

/* Issue label */
.splash-issue {
  font-family: var(--font-body);
  font-size: var(--text-xs); font-weight: 400;
  letter-spacing: 10rpx; text-transform: uppercase;
  margin-bottom: 8rpx;
}

/* Typography */
.splash-cn {
  font-family: var(--font-heading);
  font-size: 88rpx; font-weight: 700;
  letter-spacing: 8rpx; line-height: 1.1;
}
.splash-en {
  font-family: var(--font-body);
  font-size: 26rpx; font-weight: 400;
  letter-spacing: 12rpx; opacity: 0.4;
  text-transform: uppercase;
}
.splash-tagline {
  font-family: var(--font-body);
  font-size: 28rpx; font-weight: 300;
  margin-top: 24rpx; opacity: 0.55;
  font-style: italic; letter-spacing: 2rpx;
}

/* ============================================
   Editorial marks — minimal geometric
   ============================================ */
.splash-mark {
  width: 120rpx; height: 120rpx;
  display: flex; align-items: center; justify-content: center;
  margin: 24rpx 0;
  animation: markFloat 4s ease-in-out infinite;
}
@keyframes markFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* vertical line */
.mark-line-v { width: 1.5px; height: 64rpx; }

/* two horizontal lines */
.mark-lines-h { display: flex; flex-direction: column; gap: 12rpx; align-items: center; }
.mh { width: 64rpx; height: 1.5px; }

/* open circle */
.mark-circle { width: 48rpx; height: 48rpx; border: 1.5px solid; border-radius: 50%; }

/* diagonal line */
.mark-diag { width: 1.5px; height: 72rpx; transform: rotate(30deg); }

/* cross */
.mark-cross { position: relative; width: 56rpx; height: 56rpx; }
.mc { position: absolute; }
.mc:first-child { width: 1.5px; height: 56rpx; left: 27rpx; }
.mc:last-child { width: 56rpx; height: 1.5px; top: 27rpx; }

/* dot */
.mark-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }

/* three dots */
.mark-dots { display: flex; gap: 16rpx; }
.mark-dots view { width: 8rpx; height: 8rpx; border-radius: 50%; }
