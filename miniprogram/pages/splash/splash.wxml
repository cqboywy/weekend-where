<view class="splash-page {{fadeIn ? 'show' : ''}}" style="background: linear-gradient(160deg, {{issue.bg[0]}}, {{issue.bg[1]}});">
  <view class="splash-content">
    <!-- Day label -->
    <view class="splash-issue" style="color: {{issue.accent}};">{{issue.label}}</view>

    <!-- Editorial mark -->
    <view class="splash-mark {{issue.mark}}" style="border-color: {{issue.accent}}; background-color: {{issue.accent}};">
      <!-- vertical line -->
      <view wx:if="{{issue.mark === 'line-v'}}" class="mark-line-v" style="background:{{issue.accent}};"></view>
      <!-- two horizontal lines -->
      <view wx:if="{{issue.mark === 'lines-h'}}" class="mark-lines-h">
        <view class="mh" style="background:{{issue.accent}};"></view>
        <view class="mh" style="background:{{issue.accent}};"></view>
      </view>
      <!-- open circle -->
      <view wx:if="{{issue.mark === 'circle'}}" class="mark-circle" style="border-color:{{issue.accent}};"></view>
      <!-- diagonal -->
      <view wx:if="{{issue.mark === 'diagonal'}}" class="mark-diag" style="background:{{issue.accent}};"></view>
      <!-- cross -->
      <view wx:if="{{issue.mark === 'cross'}}" class="mark-cross">
        <view class="mc" style="background:{{issue.accent}};"></view>
        <view class="mc" style="background:{{issue.accent}};"></view>
      </view>
      <!-- dot -->
      <view wx:if="{{issue.mark === 'dot'}}" class="mark-dot" style="background:{{issue.accent}};"></view>
      <!-- three dots -->
      <view wx:if="{{issue.mark === 'dots'}}" class="mark-dots">
        <view style="background:{{issue.accent}};"></view>
        <view style="background:{{issue.accent}};"></view>
        <view style="background:{{issue.accent}};"></view>
      </view>
    </view>

    <!-- Titles -->
    <view class="splash-cn" style="color: {{issue.accent}};">周末去哪儿</view>
    <view class="splash-en" style="color: {{issue.accent}};">WEEKEND · WHERE</view>
    <view class="splash-tagline" style="color: {{issue.accent}};">{{issue.tagline}}</view>
  </view>
</view>
