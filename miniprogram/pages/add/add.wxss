.add-page { padding-bottom: 140rpx; background: var(--color-bg); }

/* Header */
.page-header { padding: 32rpx 24rpx 8rpx; }
.header-title { font-size: var(--text-2xl); font-weight: 700; color: var(--color-text); }
.header-desc { font-size: var(--text-base); color: var(--color-text-secondary); margin-top: 4rpx; }

/* Sections */
.section { margin: 12rpx 20rpx; padding: 24rpx 20rpx; }
.section-label {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: var(--tracking-wide);
  margin-bottom: 20rpx;
}

/* URL input */
.url-input-row { display: flex; gap: 10rpx; }
.url-input { flex: 1; background: var(--color-surface); border-radius: var(--radius-md); padding: 16rpx 20rpx; font-size: var(--text-base); }
.parse-btn {
  white-space: nowrap; background: var(--color-primary); color: #fff;
  border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600;
  padding: 12rpx 24rpx;
}
.parse-btn:active { opacity: 0.8; }

/* Form */
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: var(--text-sm); color: var(--color-text); font-weight: 500; margin-bottom: 10rpx; }
.form-label .required { color: var(--color-danger); }
.form-input {
  background: var(--color-surface); border-radius: var(--radius-md);
  padding: 18rpx 20rpx; font-size: var(--text-base); width: 100%;
  box-sizing: border-box; line-height: 1.4;
}

/* Chips */
.chip-row { display: flex; gap: 10rpx; flex-wrap: wrap; }
.chip {
  padding: 10rpx 22rpx; border-radius: var(--radius-full);
  font-size: var(--text-sm); background: var(--color-surface);
  color: var(--color-text-secondary); font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  display: inline-flex; align-items: center; line-height: 1.4;
}
.chip:active { transform: scale(0.95); }
.chip-active { background: var(--color-primary) !important; color: #fff !important; font-weight: 600; }

/* Rating */
.rating-row { display: flex; gap: 6rpx; }
.rating-star { font-size: 44rpx; color: var(--color-border); transition: color 0.15s; }
.rating-star.active { color: #F59E0B; }

/* Location */
.location-picker {
  background: var(--color-surface); border-radius: var(--radius-md);
  padding: 36rpx; text-align: center;
  border: 2rpx dashed var(--color-border);
}
.location-picker:active { background: var(--color-primary-light); border-color: var(--color-primary); }
.location-placeholder { color: var(--color-text-secondary); font-size: var(--text-base); }
.location-selected { text-align: left; }
.location-name { font-size: var(--text-md); font-weight: 600; }
.location-addr { font-size: var(--text-sm); color: var(--color-text-secondary); margin-top: 6rpx; }
.location-change { font-size: var(--text-xs); color: var(--color-primary); margin-top: 6rpx; font-weight: 500; }

/* Tags input */
.tag-input-row { display: flex; gap: 10rpx; margin-bottom: 16rpx; align-items: center; }
.tag-input { flex: 1; }
.tag-add-btn { background: var(--color-primary); color: #fff; border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600; }
.tag-list { display: flex; flex-wrap: wrap; gap: 10rpx; }
.tag-item {
  display: inline-flex; align-items: center;
  padding: 10rpx 20rpx; background: var(--color-primary-light);
  color: var(--color-primary); border-radius: var(--radius-full);
  font-size: var(--text-sm); font-weight: 500;
  line-height: 1.4; white-space: nowrap; max-width: 100%;
}
.tag-remove { margin-left: 10rpx; font-size: 20rpx; padding: 2rpx 6rpx; opacity: 0.6; }

/* Note */
.note-input {
  background: var(--color-surface); border-radius: var(--radius-md);
  padding: 18rpx 20rpx; font-size: var(--text-base);
  width: 100%; box-sizing: border-box; min-height: 140rpx; line-height: 1.5;
}

/* Bottom bar */
.bottom-actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: 12rpx; padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.92); backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid var(--color-border); z-index: 100;
}
.reset-btn { flex: 1; background: var(--color-surface); color: var(--color-text-secondary); border-radius: var(--radius-full); font-size: var(--text-base); font-weight: 500; }
.submit-btn { flex: 2; background: var(--color-primary); color: #fff; border-radius: var(--radius-full); font-size: var(--text-base); font-weight: 700; }
