.add-page { padding-bottom: 160rpx; background: var(--color-bg); }

/* Header */
.page-header { padding: 36rpx 28rpx 16rpx; }
.header-title { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 700; }
.header-desc { font-size: var(--text-base); color: var(--color-primary); margin-top: 6rpx; font-style: italic; }

/* Sections */
.section { margin: 12rpx 24rpx; padding: 28rpx 24rpx; }
.section-label {
  font-size: var(--text-xs); color: var(--color-primary); font-weight: 600;
  text-transform: uppercase; letter-spacing: var(--tracking-widest); margin-bottom: 20rpx;
}

/* URL */
.url-input-row { display: flex; gap: 12rpx; }
.url-input { flex: 1; background: var(--color-surface); border-radius: var(--radius-full); padding: 18rpx 28rpx; font-size: var(--text-base); }
.parse-btn {
  white-space: nowrap; background: var(--color-primary); color: #fff;
  border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600;
  padding: 14rpx 28rpx; letter-spacing: var(--tracking-wide); text-transform: uppercase;
  transition: opacity 0.3s ease;
}
.parse-btn:active { opacity: 0.8; }

/* Form */
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: var(--text-sm); color: var(--color-text); font-weight: 500; margin-bottom: 12rpx; }
.form-label .required { color: var(--color-accent); }
.form-input {
  background: var(--color-surface); border-radius: var(--radius-full);
  padding: 20rpx 28rpx; font-size: var(--text-base); width: 100%;
  box-sizing: border-box; line-height: 1.4;
}

/* Chips */
.chip-row { display: flex; gap: 10rpx; flex-wrap: wrap; }
.chip {
  padding: 12rpx 24rpx; border-radius: var(--radius-full);
  font-size: var(--text-sm); background: var(--color-white); color: var(--color-primary);
  font-weight: 500; border: 1rpx solid var(--color-border);
  display: inline-flex; align-items: center; line-height: 1.4;
  transition: all 0.3s ease;
}
.chip:active { transform: scale(0.95); }
.chip-active { background: var(--color-primary) !important; color: #fff !important; border-color: var(--color-primary); font-weight: 600; }

/* Rating */
.rating-row { display: flex; gap: 4rpx; }
.rating-star { font-size: 44rpx; color: var(--color-border); transition: color 0.2s; }
.rating-star.active { color: #C27B66; }

/* Location */
.location-picker {
  background: var(--color-surface); border-radius: var(--radius-lg);
  padding: 40rpx; text-align: center; border: 2rpx dashed var(--color-border);
  transition: all 0.3s ease;
}
.location-picker:active { background: rgba(140,154,132,0.05); border-color: var(--color-primary); }
.location-placeholder { color: var(--color-primary); font-size: var(--text-base); }
.location-selected { text-align: left; }
.location-name { font-family: var(--font-heading); font-size: var(--text-md); font-weight: 600; }
.location-addr { font-size: var(--text-sm); color: var(--color-primary); margin-top: 6rpx; }
.location-change { font-size: var(--text-xs); color: var(--color-accent); margin-top: 8rpx; font-weight: 500; }

/* Tags */
.tag-input-row { display: flex; gap: 10rpx; margin-bottom: 16rpx; align-items: center; }
.tag-input { flex: 1; }
.tag-add-btn { background: var(--color-primary); color: #fff; border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600; letter-spacing: var(--tracking-wide); text-transform: uppercase; }
.tag-list { display: flex; flex-wrap: wrap; gap: 10rpx; }
.tag-item {
  display: inline-flex; align-items: center;
  padding: 12rpx 22rpx; background: rgba(140,154,132,0.08);
  color: var(--color-primary); border-radius: var(--radius-full);
  font-size: var(--text-sm); font-weight: 500;
  line-height: 1.4; white-space: nowrap; max-width: 100%;
  border: 1rpx solid var(--color-border);
}
.tag-remove { margin-left: 10rpx; font-size: 20rpx; padding: 2rpx 6rpx; opacity: 0.5; }

/* Note */
.note-input {
  background: var(--color-surface); border-radius: var(--radius-lg);
  padding: 20rpx 28rpx; font-size: var(--text-base);
  width: 100%; box-sizing: border-box; min-height: 160rpx; line-height: 1.6;
}

/* Bottom */
.bottom-actions {
  position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 12rpx;
  padding: 16rpx 24rpx; background: rgba(249,248,244,0.95);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-top: 1rpx solid var(--color-border); z-index: 100;
}
.reset-btn { flex: 1; background: var(--color-surface); color: var(--color-primary); border-radius: var(--radius-full); font-size: var(--text-base); font-weight: 500; border: 1rpx solid var(--color-border); }
.submit-btn { flex: 2; background: var(--color-primary); color: #fff; border-radius: var(--radius-full); font-size: var(--text-base); font-weight: 700; letter-spacing: var(--tracking-wide); text-transform: uppercase; transition: opacity 0.3s ease; }
