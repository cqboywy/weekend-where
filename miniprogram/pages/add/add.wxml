<view class="page add-page">
  <view class="page-header">
    <view class="header-desc">{{isEditing ? '· 编辑 ·' : '· 新收藏 ·'}}</view>
  </view>

  <view class="section card">
    <view class="section-label">封面图片</view>
    <view class="cover-picker" bindtap="onChooseCover">
      <image wx:if="{{coverImageTemp || formData.coverImage}}"
             src="{{coverImageTemp || formData.coverImage}}"
             mode="aspectFill" class="cover-preview" />
      <view wx:else class="cover-placeholder">
        <lucide-icon name="plus-circle" size="44" color="#C4B5A8" />
        <text class="cover-hint">点击添加封面图片（可选）</text>
      </view>
    </view>
    <view wx:if="{{coverImageTemp || formData.coverImage}}" class="cover-actions">
      <text class="cover-retake" catchtap="onChooseCover">重新选择</text>
      <text class="cover-remove" catchtap="onRemoveCover">移除</text>
    </view>
  </view>

  <view class="section card">
    <view class="section-label">基本信息</view>
    <view class="form-item">
      <view class="form-label">名称 <text class="required">*</text></view>
      <input class="form-input" placeholder="输入名称" value="{{formData.title}}" bindinput="onTitleInput"/>
    </view>
    <view class="form-item">
      <view class="form-label">分类 <text class="required">*</text></view>
      <view class="chip-row chip-row-wrap">
        <block wx:for="{{categories}}" wx:key="key">
          <view class="chip {{formData.category === item.key ? 'chip-active' : ''}}" data-category="{{item.key}}" bindtap="onSelectCategory">{{item.label}}</view>
        </block>
      </view>
    </view>
    <view class="form-item">
      <view class="form-label">评分</view>
      <view class="rating-row">
        <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="rating-star {{index < formData.rating ? 'active' : ''}}" data-rate="{{index + 1}}" bindtap="onRate">★</text>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="section-label">位置信息</view>
    <view class="form-item">
      <view class="location-picker" bindtap="onChooseLocation">
        <view wx:if="{{!formData.locationName}}" class="location-placeholder">点击选择地点位置</view>
        <view wx:else class="location-selected">
          <view class="location-name">📍 {{formData.locationName}}</view>
          <view class="location-addr">{{formData.locationAddress}}</view>
          <view class="location-change">点击更换</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="section-label">自定义标签</view>
    <view class="tag-input-row">
      <input class="form-input tag-input" placeholder="输入或搜索已有标签" value="{{tagInput}}" bindinput="onTagInput" bindconfirm="onAddTag"/>
      <button class="tag-add-btn" bindtap="onAddTag">添加</button>
    </view>
    <view wx:if="{{existingTags.length > 0}}" class="existing-tags">
      <view class="existing-tags-label">{{tagInput ? '匹配标签（点击添加）' : '常用标签（输入可搜索）'}}</view>
      <view class="existing-tags-row">
        <view wx:for="{{existingTags}}" wx:for-item="tag" wx:key="*this" class="existing-tag-chip" data-tag="{{tag}}" bindtap="onTapExistingTag">{{tag}}</view>
      </view>
      <view wx:if="{{hasMoreTags && !tagInput}}" class="expand-row">
        <view class="expand-btn" bindtap="onToggleExpand">
          <text>{{tagsExpanded ? '收起' : '展开全部'}}</text>
          <lucide-icon wx:if="{{!tagsExpanded}}" name="chevron-down" size="16" color="#9E9688" />
          <lucide-icon wx:else name="chevron-up" size="16" color="#9E9688" />
        </view>
      </view>
    </view>
    <view wx:if="{{formData.tags.length > 0}}" class="tag-list">
      <view wx:for="{{formData.tags}}" wx:key="*this" class="tag-item">{{item}}<text class="tag-remove" data-index="{{index}}" bindtap="onRemoveTag">✕</text></view>
    </view>
  </view>

  <view class="section card">
    <view class="section-label">备注</view>
    <textarea class="note-input" placeholder="记录一些想说的话（人均消费、推荐菜、备注等）" value="{{formData.note}}" bindinput="onNoteInput" maxlength="200" auto-height/>
  </view>

  <view class="bottom-actions safe-area-bottom">
    <view class="reset-btn pressable" bindtap="onReset">清空</view>
    <button class="submit-btn plain-btn pressable" bindtap="onSubmit" disabled="{{submitting}}" loading="{{submitting}}">{{isUploading ? '上传中…' : (submitting ? '保存中…' : (isEditing ? '保存修改' : '加入收藏'))}}</button>
  </view>
</view>
