.index-page { padding-bottom: 80rpx; }

/* ============================================
   Hero
   ============================================ */
.hero { padding: 120rpx 40rpx 48rpx; }
.hero-badge {
  display: inline-block;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--color-primary);
  font-weight: 500;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  margin-bottom: 28rpx;
  padding: 6rpx 0;
  border-bottom: 1.5px solid var(--color-primary);
}
.hero-headline {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}
.hero-title {
  font-family: var(--font-heading);
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--color-text);
  line-height: var(--leading-tight);
}
.hero-temp {
  font-family: var(--font-heading);
  font-size: var(--text-sm);
  color: var(--color-accent);
  font-weight: 400;
  letter-spacing: 1rpx;
}
.hero-date {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-muted);
  margin-top: 20rpx;
  letter-spacing: 2rpx;
}

/* ============================================
   Featured daily pick
   ============================================ */
.featured-section { margin: 0 28rpx 48rpx; }
.featured-card {
  position: relative; border-radius: var(--radius-lg);
  overflow: hidden; height: 480rpx;
  box-shadow: 0 2rpx 16rpx rgba(44,36,22,0.06), 0 0 0 1px rgba(44,36,22,0.03);
}
.featured-cover { width: 100%; height: 100%; }
.featured-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 60rpx 32rpx 36rpx;
  background: linear-gradient(to top, rgba(30,18,10,0.65), transparent);
  display: flex; flex-direction: column; gap: 8rpx;
}
.featured-tag {
  display: inline-block; width: fit-content;
  padding: 6rpx 18rpx; border-radius: var(--radius-full);
  font-size: var(--text-xs); color: #fff; font-weight: 700;
  background: rgba(255,255,255,0.22); backdrop-filter: blur(8px);
  letter-spacing: var(--tracking-wide); margin-bottom: 8rpx;
}
.featured-title {
  font-family: var(--font-heading);
  font-size: var(--text-xl); font-weight: 700;
  color: #fff; line-height: var(--leading-tight);
}
.featured-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.featured-tag-chip {
  font-size: var(--text-xs); color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.featured-card:active { transform: scale(0.98); transition: transform 0.2s ease; }

/* ============================================
   Masonry section
   ============================================ */
.masonry-section { margin: 0 28rpx; padding-bottom: 48rpx; }
.section-head {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 28rpx; padding-bottom: 16rpx;
  border-bottom: 1px solid var(--color-border);
}
.section-title { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; }
.section-link { font-size: var(--text-sm); color: var(--color-muted); font-weight: 500; }

.masonry-grid { column-count: 2; column-gap: 16rpx; }
.masonry-item {
  break-inside: avoid; margin-bottom: 16rpx;
  background: var(--color-white); border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 1rpx 8rpx rgba(44,36,22,0.05), 0 0 0 1px rgba(44,36,22,0.03);
  transition: transform 0.25s cubic-bezier(0.32, 0.72, 0, 1), box-shadow 0.3s ease;
}
.masonry-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(44,36,22,0.10), 0 0 0 1px rgba(44,36,22,0.05);
}
.masonry-img {
  width: 100%; display: block;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}
.masonry-body { padding: 20rpx 22rpx 24rpx; }
.masonry-title {
  font-family: var(--font-heading);
  font-size: var(--text-md); font-weight: 700;
  color: var(--color-text); line-height: var(--leading-tight);
  margin-bottom: 10rpx;
  display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden;
}
.masonry-cat {
  display: inline-block; padding: 4rpx 12rpx;
  border-radius: var(--radius-full); font-size: var(--text-xs); font-weight: 500;
}

/* ============================================
   Skeleton
   ============================================ */
.skeleton-card { }
.skeleton-img { width: 100%; height: 260rpx; background: var(--color-border); }
.skeleton-line { height: 24rpx; background: var(--color-border); border-radius: 6rpx; margin-bottom: 12rpx; }
.w-80 { width: 80%; }
.w-50 { width: 50%; }
