.index-page { padding-bottom: 80rpx; }

/* ============================================
   Hero
   ============================================ */
.hero { padding: 104rpx 36rpx 36rpx; }
.hero-badge {
  display: inline-block;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--color-accent);
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 20rpx;
  background: var(--color-accent-soft);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
}
.hero-title {
  font-family: var(--font-heading);
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--color-text);
  line-height: var(--leading-tight);
}
.hero-sub {
  font-family: var(--font-body);
  font-size: var(--text-base);
  color: var(--color-muted);
  margin-top: 14rpx;
  font-style: italic;
}

/* ============================================
   Featured daily pick
   ============================================ */
.featured-section { margin: 0 24rpx 40rpx; }
.featured-card {
  position: relative; border-radius: var(--radius-xl);
  overflow: hidden; height: 480rpx;
  box-shadow: var(--shadow-elevated);
}
.featured-cover { width: 100%; height: 100%; }
.featured-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 60rpx 32rpx 36rpx;
  background: linear-gradient(to top, rgba(30,18,10,0.65), transparent);
  display: flex; flex-direction: column; gap: 8rpx;
}
.featured-tag {
  display: inline-block; width: fit-content;
  padding: 6rpx 18rpx; border-radius: var(--radius-full);
  font-size: var(--text-xs); color: #fff; font-weight: 700;
  background: rgba(255,255,255,0.22); backdrop-filter: blur(8px);
  letter-spacing: var(--tracking-wide); margin-bottom: 8rpx;
}
.featured-title {
  font-family: var(--font-heading);
  font-size: var(--text-xl); font-weight: 700;
  color: #fff; line-height: var(--leading-tight);
}
.featured-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.featured-tag-chip {
  font-size: var(--text-xs); color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.featured-card:active { transform: scale(0.98); transition: transform 0.2s ease; }

/* ============================================
   Masonry section
   ============================================ */
.masonry-section { margin: 0 24rpx; padding-bottom: 40rpx; }
.section-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 20rpx; }
.section-title { font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 700; }
.section-link { font-size: var(--text-sm); color: var(--color-primary); font-weight: 600; }

.masonry-grid { column-count: 2; column-gap: 16rpx; }
.masonry-item {
  break-inside: avoid; margin-bottom: 16rpx;
  background: var(--color-white); border-radius: var(--radius-lg);
  overflow: hidden; box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
}
.masonry-item:active { transform: scale(0.975); }
.masonry-img {
  width: 100%; display: block;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}
.masonry-body { padding: 18rpx 20rpx 22rpx; }
.masonry-title {
  font-family: var(--font-heading);
  font-size: var(--text-md); font-weight: 700;
  color: var(--color-text); line-height: var(--leading-tight);
  margin-bottom: 10rpx;
  display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden;
}
.masonry-cat {
  display: inline-block; padding: 4rpx 14rpx;
  border-radius: var(--radius-full); font-size: var(--text-xs); font-weight: 600;
}

/* ============================================
   Skeleton
   ============================================ */
.skeleton-card { }
.skeleton-img { width: 100%; height: 260rpx; background: var(--color-border); }
.skeleton-line { height: 24rpx; background: var(--color-border); border-radius: 6rpx; margin-bottom: 12rpx; }
.w-80 { width: 80%; }
.w-50 { width: 50%; }
