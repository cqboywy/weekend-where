<view class="page index-page">
  <!-- Hero -->
  <view class="hero">
    <view class="hero-badge">WEEKEND · WHERE</view>
    <view class="hero-headline">
      <text class="hero-title">{{greeting}}</text>
      <text wx:if="{{weatherDetail}}" class="hero-temp">{{weatherDetail}}</text>
    </view>
    <view class="hero-date">{{currentDate}}</view>
  </view>

  <!-- Featured daily pick -->
  <view wx:if="{{featuredItem}}" class="featured-section">
    <view class="featured-card pressable" bindtap="onViewFeatured">
      <image src="{{featuredItem.displayCover}}" mode="aspectFill" class="featured-cover"/>
      <view class="featured-overlay">
        <view class="featured-tag">今日精选</view>
        <view class="featured-title">{{featuredItem.title}}</view>
        <view wx:if="{{featuredItem.tags && featuredItem.tags.length > 0}}" class="featured-tags">
          <text wx:for="{{featuredItem.tags}}" wx:for-item="t" wx:key="*this" class="featured-tag-chip">#{{t}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Next Go -->
  <view wx:if="{{nextGoItems.length > 0}}" class="nextgo-section">
    <view class="section-head">
      <view class="section-title">下次去</view>
      <view class="section-count">{{nextGoItems.length}} 个地方</view>
    </view>
    <view class="nextgo-scroll">
      <view wx:for="{{nextGoItems}}" wx:key="_id" class="nextgo-item">
        <view class="nextgo-card pressable" bindtap="onViewNextGo" data-id="{{item._id}}">
          <image src="{{item.displayCover}}" mode="aspectFill" class="nextgo-cover"/>
          <view class="nextgo-info">
            <view class="nextgo-title ellipsis">{{item.title}}</view>
            <view class="nextgo-cat" style="color:{{item.catColor}};">{{item.catLabel}}</view>
          </view>
        </view>
        <view class="nextgo-remove pressable" catchtap="onRemoveNextGo" data-id="{{item._id}}">
          <lucide-icon name="x" size="28" color="#9E9688" />
        </view>
      </view>
    </view>
  </view>

  <!-- Past collections — masonry grid -->
  <view class="masonry-section">
    <view class="section-head">
      <view class="section-title">往期收藏</view>
      <view class="section-link" bindtap="onGoList">全部 →</view>
    </view>

    <view wx:if="{{loading}}">
      <view class="masonry-grid">
        <view class="masonry-item skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
          <view class="masonry-img skeleton-img"></view>
          <view class="masonry-body">
            <view class="skeleton-line w-80"></view>
            <view class="skeleton-line w-50"></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{recentItems.length === 0}}">
      <empty-state title="还没有收藏" description="去添加你的第一个好吃好玩的地方吧" bind:action="onGoAdd"/>
    </view>

    <view wx:else class="masonry-grid">
      <view wx:for="{{recentItems}}" wx:key="_id" class="masonry-item pressable" bindtap="onViewDetail" data-id="{{item._id}}">
        <image src="{{item.displayCover}}" mode="widthFix" class="masonry-img"/>
        <view class="masonry-body">
          <view class="masonry-title">{{item.title}}</view>
          <view class="masonry-cat" style="color:{{item.catColor || '#E8876A'}}; background:{{item.catBg || '#FFF0E8'}};">{{item.catLabel || '其他'}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
