<view wx:if="{{!loading && item}}" class="page detail-page">
  <!-- Cover -->
  <view class="detail-cover">
    <image src="{{displayCover}}" mode="aspectFill" class="cover-image"/>
    <view class="cover-gradient"></view>
    <view class="cover-status">{{statusLabel}}</view>
  </view>

  <!-- Info section -->
  <view class="detail-section card-elevated">
    <view class="detail-title">{{item.title}}</view>
    <view class="detail-meta">
      <view class="category-badge tag tag-primary">
        <lucide-icon name="tag" size="24" />
        {{categoryInfo.label || '未分类'}}
      </view>
      <view wx:if="{{item.rating > 0}}" class="detail-rating">
        <text wx:for="{{[1,2,3,4,5]}}" wx:for-item="s" wx:key="*this" class="star {{index < item.rating ? 'star-on' : 'star-off'}}">★</text>
      </view>
    </view>
    <view wx:if="{{item.tags && item.tags.length > 0}}" class="detail-tags">
      <view wx:for="{{item.tags}}" wx:key="*this" class="tag tag-accent">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{item.location && item.location.name}}" class="detail-section card">
    <view class="section-label"><lucide-icon name="map-pin" size="24" color="#E8876A" /> 位置</view>
    <view class="location-name">{{item.location.name}}</view>
    <view wx:if="{{distanceText}}" class="detail-distance">
      <lucide-icon name="navigation" size="20" color="#E8876A" />
      <text>距你 {{distanceText}}</text>
    </view>
    <view wx:if="{{item.location.address}}" class="location-addr">{{item.location.address}}</view>
  </view>

  <view wx:if="{{item.note}}" class="detail-section card">
    <view class="section-label">
      <lucide-icon name="info" size="24" color="#E8876A" /> 备注
      <text class="note-copy pressable" catchtap="onCopyNote">复制</text>
    </view>
    <view class="note-content">{{item.note}}</view>
  </view>

  <view wx:if="{{item.originalUrl}}" class="detail-section card">
    <view class="section-label"><lucide-icon name="share" size="24" color="#E8876A" /> 来源</view>
    <view class="link-row" bindtap="onOpenOriginal">
      <view class="link-url ellipsis">{{item.originalUrl}}</view>
      <view class="link-arrow">→</view>
    </view>
  </view>

  <!-- Secondary actions -->
  <view class="detail-aux-row">
    <view class="aux-btn pressable" bindtap="onEdit">
      <lucide-icon name="pencil" size="20" color="#9E9688" />
      <text>编辑</text>
    </view>
    <button class="aux-btn pressable plain-btn" open-type="share">
      <lucide-icon name="share" size="20" color="#9E9688" />
      <text>分享</text>
    </button>
    <view class="aux-btn pressable" bindtap="onDelete">
      <lucide-icon name="trash-2" size="20" color="#D4735E" />
      <text>删除</text>
    </view>
  </view>

  <!-- Bottom actions -->
  <view class="detail-actions safe-area-bottom">
    <view class="action-btn pressable" bindtap="onToggleStatus">
      <lucide-icon name="check" size="26" color="{{item.status === 'visited' ? '#7C9A7E' : '#6E6658'}}" />
      <text>{{item.status === 'visited' ? '想去' : '去过'}}</text>
    </view>
    <view class="action-btn pressable" bindtap="onToggleNextGo">
      <lucide-icon name="bookmark" size="26" color="{{item.nextGo ? '#C2674A' : '#6E6658'}}" />
      <text>{{item.nextGo ? '已计划' : '计划去'}}</text>
    </view>
    <view class="action-btn primary pressable" bindtap="onNavigate">
      <lucide-icon name="navigation" size="26" color="#fff" />
      <text>导航到此处</text>
    </view>
  </view>
</view>

<view wx:elif="{{loading}}"><skeleton loading="{{true}}" count="{{1}}"/></view>
