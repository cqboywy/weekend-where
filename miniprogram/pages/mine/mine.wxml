<view class="page mine-page">
  <view class="mine-header">
    <view class="avatar"><lucide-icon name="user" size="52" color="#9E9688" /></view>
    <view class="header-issue">WEEKEND · WHERE</view>
    <view class="nickname">周末去哪儿</view>
    <view class="bio">收藏 {{stats ? stats.total : '...'}} 个好吃好玩的地方</view>
  </view>

  <view wx:if="{{stats}}" class="stats-section card-elevated">
    <view class="stats-row">
      <view class="stat-item pressable" bindtap="onTapStat" data-status="">
        <view class="stat-num">{{stats.total}}</view><view class="stat-label">总收藏</view></view>
      <view class="stat-divider"></view>
      <view class="stat-item pressable" bindtap="onTapStat" data-status="want_to_go">
        <view class="stat-num">{{stats.wantToGo}}</view><view class="stat-label">想去</view></view>
      <view class="stat-divider"></view>
      <view class="stat-item pressable" bindtap="onTapStat" data-status="visited">
        <view class="stat-num">{{stats.visited}}</view><view class="stat-label">去过</view></view>
    </view>
  </view>

  <view wx:if="{{tagStats.length > 0}}" class="tag-section card">
    <view class="section-head"><view class="section-title">标签统计</view></view>
    <view class="tag-grid">
      <view wx:for="{{tagStats}}" wx:key="tag" class="tag-stat-chip pressable" data-tag="{{item.tag}}" bindtap="onTapStatTag">{{item.tag}}<text class="tag-stat-num">{{item.count}}</text></view>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item pressable" bindtap="onManageCategories"><view class="menu-icon"><lucide-icon name="tag" size="32" color="#9E9688" /></view><view class="menu-text">分类管理</view><view class="menu-arrow"><lucide-icon name="chevron-right" size="24" color="#C8BFB2" /></view></view>
    <view class="menu-item pressable" bindtap="onExport"><view class="menu-icon"><lucide-icon name="download" size="32" color="#9E9688" /></view><view class="menu-text">导出收藏</view><view class="menu-arrow"><lucide-icon name="chevron-right" size="24" color="#C8BFB2" /></view></view>
    <view class="menu-item pressable" bindtap="onFeedback"><view class="menu-icon"><lucide-icon name="message-circle" size="32" color="#9E9688" /></view><view class="menu-text">意见反馈</view><view class="menu-arrow"><lucide-icon name="chevron-right" size="24" color="#C8BFB2" /></view></view>
    <view class="menu-item pressable" bindtap="onAbout"><view class="menu-icon"><lucide-icon name="info" size="32" color="#9E9688" /></view><view class="menu-text">关于</view><view class="menu-arrow"><lucide-icon name="chevron-right" size="24" color="#C8BFB2" /></view></view>
  </view>
</view>
