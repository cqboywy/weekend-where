<view class="page mine-page">
  <view class="mine-header">
    <view class="avatar"><lucide-icon name="user" size="56" color="#E8876A" /></view>
    <view class="nickname">美食探险家</view>
    <view class="bio">收藏 {{stats ? stats.total : '...'}} 个好吃好玩的地方</view>
  </view>

  <view wx:if="{{stats}}" class="stats-section card-elevated">
    <view class="stats-row">
      <view class="stat-item pressable" bindtap="onTapStat" data-status="">
        <view class="stat-num">{{stats.total}}</view><view class="stat-label">总收藏</view></view>
      <view class="stat-divider"></view>
      <view class="stat-item pressable" bindtap="onTapStat" data-status="want_to_go">
        <view class="stat-num">{{stats.wantToGo}}</view><view class="stat-label">想去</view></view>
      <view class="stat-divider"></view>
      <view class="stat-item pressable" bindtap="onTapStat" data-status="visited">
        <view class="stat-num">{{stats.visited}}</view><view class="stat-label">去过</view></view>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item pressable" bindtap="onManageCategories"><view class="menu-icon"><lucide-icon name="tag" size="36" color="#E8876A" /></view><view class="menu-text">分类管理</view><view class="menu-arrow"><lucide-icon name="chevron-right" size="28" color="#C8B8A8" /></view></view>
    <view class="menu-item pressable" bindtap="onExport"><view class="menu-icon"><lucide-icon name="download" size="36" color="#E8876A" /></view><view class="menu-text">导出收藏</view><view class="menu-arrow"><lucide-icon name="chevron-right" size="28" color="#C8B8A8" /></view></view>
    <view class="menu-item pressable" bindtap="onFeedback"><view class="menu-icon"><lucide-icon name="message-circle" size="36" color="#E8876A" /></view><view class="menu-text">意见反馈</view><view class="menu-arrow"><lucide-icon name="chevron-right" size="28" color="#C8B8A8" /></view></view>
    <view class="menu-item pressable" bindtap="onAbout"><view class="menu-icon"><lucide-icon name="info" size="36" color="#E8876A" /></view><view class="menu-text">关于</view><view class="menu-arrow"><lucide-icon name="chevron-right" size="28" color="#C8B8A8" /></view></view>
  </view>
</view>
