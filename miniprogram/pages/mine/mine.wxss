.mine-page { min-height: 100vh; background: var(--color-bg); }

.mine-header {
  padding: 80rpx 32rpx 48rpx;
  display: flex; flex-direction: column; align-items: center;
}
.avatar {
  width: 120rpx; height: 120rpx;
  background: var(--color-primary-light);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 60rpx;
  margin-bottom: 20rpx;
}
.nickname { font-size: var(--text-xl); font-weight: 700; color: var(--color-text); }
.bio { font-size: var(--text-base); color: var(--color-text-secondary); margin-top: 6rpx; }

.stats-section { margin: 0 24rpx 24rpx; padding: 32rpx 20rpx; }
.stats-row { display: flex; align-items: center; }
.stat-item { flex: 1; text-align: center; }
.stat-divider { width: 1rpx; height: 48rpx; background: var(--color-border); }
.stat-num { font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); line-height: 1; margin-bottom: 6rpx; }
.stat-label { font-size: var(--text-xs); color: var(--color-text-tertiary); font-weight: 500; }

.menu-section { margin: 0 24rpx; }
.menu-item { display: flex; align-items: center; padding: 28rpx 0; }
.menu-item + .menu-item { border-top: 1rpx solid var(--color-border); }
.menu-icon { font-size: 36rpx; width: 56rpx; text-align: center; }
.menu-text { flex: 1; font-size: var(--text-base); color: var(--color-text); font-weight: 500; }
.menu-arrow { font-size: 32rpx; color: var(--color-text-tertiary); }
