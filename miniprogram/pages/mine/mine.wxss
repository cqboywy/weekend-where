.mine-page { min-height: 100vh; background: var(--color-bg); }

.mine-header {
  padding: 88rpx 32rpx 56rpx;
  display: flex; flex-direction: column; align-items: center;
}
.avatar {
  width: 140rpx; height: 140rpx;
  background: var(--color-primary-soft); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
}
.nickname { font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 700; }
.bio { font-size: var(--text-base); color: var(--color-muted); margin-top: 8rpx; font-style: italic; }

.stats-section { margin: 0 24rpx 28rpx; padding: 36rpx 24rpx; }
.stats-row { display: flex; align-items: center; }
.stat-item { flex: 1; text-align: center; }
.stat-divider { width: 1rpx; height: 52rpx; background: var(--color-border); }
.stat-num { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 700; color: var(--color-primary); line-height: 1; margin-bottom: 8rpx; }
.stat-label { font-size: var(--text-xs); color: var(--color-muted); font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-widest); }

.menu-section { margin: 0 24rpx; }
.menu-item { display: flex; align-items: center; padding: 30rpx 0; }
.menu-item + .menu-item { border-top: 1rpx solid var(--color-border); }
.menu-icon { width: 60rpx; text-align: center; }
.menu-text { flex: 1; font-size: var(--text-base); color: var(--color-text); font-weight: 500; }
.menu-arrow { opacity: 0.6; }

/* Tag stats — leaderboard style */
.tag-section { margin: 28rpx 24rpx; padding: 28rpx 24rpx; }
.section-head { margin-bottom: 24rpx; }
.section-title { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; }
.tag-grid { display: flex; flex-wrap: wrap; gap: 0; }
.tag-stat-chip {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: 20rpx 12rpx;
  font-size: var(--text-sm); color: var(--color-text); font-weight: 500;
  border-bottom: 1rpx solid var(--color-border);
}
.tag-stat-chip:last-child { border-bottom: none; }
.tag-stat-num {
  font-weight: 700; font-size: var(--text-sm);
  color: var(--color-primary); min-width: 44rpx; text-align: center;
}
