.mine-page { min-height: 100vh; background: var(--color-bg); }

.mine-header {
  padding: 96rpx 32rpx 60rpx;
  display: flex; flex-direction: column; align-items: center;
}
.avatar {
  width: 140rpx; height: 140rpx; border-radius: var(--radius-lg);
  margin-bottom: 36rpx; overflow: hidden;
}
.header-issue {
  font-family: var(--font-body); font-size: var(--text-xs);
  color: var(--color-muted); font-weight: 500;
  letter-spacing: 6rpx; text-transform: uppercase;
  margin-bottom: 12rpx;
}
.nickname {
  font-family: var(--font-heading); font-size: 48rpx; font-weight: 600;
  letter-spacing: 8rpx; position: relative;
}
.nickname::after {
  content: ''; display: block;
  width: 48rpx; height: 1.5px;
  background: var(--color-primary);
  margin: 20rpx auto 0;
}
.bio { font-size: var(--text-sm); color: var(--color-muted); margin-top: 28rpx; font-weight: 300; letter-spacing: 1rpx; }

.stats-section { margin: 0 28rpx 32rpx; padding: 40rpx 28rpx; }
.stats-row { display: flex; align-items: center; }
.stat-item { flex: 1; text-align: center; }
.stat-divider { width: 1rpx; height: 52rpx; background: var(--color-border); }
.stat-num { font-family: var(--font-body); font-size: 72rpx; font-weight: 300; color: var(--color-primary); line-height: 1; margin-bottom: 8rpx; letter-spacing: -2rpx; }
.stat-label { font-size: var(--text-xs); color: var(--color-muted); font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-widest); }

.menu-section { margin: 0 28rpx; }
.menu-item { display: flex; align-items: center; padding: 36rpx 0; }
.menu-item + .menu-item { border-top: 1rpx solid var(--color-border); }
.menu-icon { width: 60rpx; text-align: center; }
.menu-text { flex: 1; font-size: var(--text-base); color: var(--color-text); font-weight: 400; }
.menu-arrow { opacity: 0.5; }

/* Tag stats — leaderboard style */
.tag-section { margin: 32rpx 28rpx; padding: 28rpx 28rpx; }
.section-head { margin-bottom: 24rpx; }
.section-title { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; }
.tag-grid { display: flex; flex-wrap: wrap; gap: 0; }
.tag-stat-chip {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: 20rpx 12rpx;
  font-size: var(--text-sm); color: var(--color-text); font-weight: 500;
  border-bottom: 1rpx solid var(--color-border);
}
.tag-stat-chip:last-child { border-bottom: none; }
.tag-stat-num {
  font-weight: 700; font-size: var(--text-sm);
  color: var(--color-primary); min-width: 44rpx; text-align: center;
}
.tag-more {
  text-align: center; padding: 16rpx 0 4rpx;
  font-size: var(--text-xs); color: var(--color-muted);
  font-weight: 500;
}
