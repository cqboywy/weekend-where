<view class="page map-page">
  <map id="myMap" class="map-container" latitude="{{latitude}}" longitude="{{longitude}}" scale="{{scale}}" markers="{{markers}}" bindmarkertap="onMarkerTap" bindcallouttap="onMarkerTap" show-location="{{true}}"/>

  <view class="map-filter-bar">
    <scroll-view class="map-filter-scroll" scroll-x>
      <view class="filter-row">
        <view class="mode-chip pressable" bindtap="onToggleFilterMode">{{filterMode === 'category' ? '分类 ▾' : '标签 ▾'}}</view>
        <view wx:if="{{filterMode === 'category'}}" wx:for="{{categories}}" wx:key="key" class="map-chip pressable {{selectedCategory === item.key ? 'active' : ''}}" data-category="{{item.key}}" bindtap="onSelectCategory">{{item.label}}</view>
        <view wx:if="{{filterMode === 'tag'}}" wx:for="{{allTags}}" wx:key="tag" class="map-chip pressable {{selectedTag === item.tag ? 'active' : ''}}" data-tag="{{item.tag}}" bindtap="onSelectTag">{{item.label}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="locate-btn pressable" bindtap="onMoveToCurrent">
    <lucide-icon name="navigation" size="36" color="#E8876A" />
  </view>

  <view wx:if="{{!showDistanceSort}}" class="sort-btn pressable" bindtap="onOpenDistanceSort">
    <text>最近</text>
  </view>

  <!-- Distance sort button -->
  <view wx:if="{{!showDistanceSort}}" class="sort-btn pressable" bindtap="onOpenDistanceSort">
    <lucide-icon name="navigation" size="36" color="#E8876A" />
  </view>

  <view class="locate-btn pressable" bindtap="onMoveToCurrent">
    <lucide-icon name="navigation" size="36" color="#E8876A" />
  </view>

  <!-- Hidden canvas for generating marker icons -->
  <canvas type="2d" id="markerCanvas" style="position:fixed;left:-9999px;width:64px;height:64px;"></canvas>

  <!-- Distance sort bottom sheet -->
  <view wx:if="{{showDistanceSort}}" class="sort-overlay" bindtap="onCloseDistanceSort">
    <view class="sort-sheet safe-area-bottom" catchtap="noop">
      <view class="sort-sheet-head">
        <text>距我最近</text>
        <view class="sort-close pressable" bindtap="onCloseDistanceSort">
          <lucide-icon name="x" size="32" color="#9E9688" />
        </view>
      </view>
      <scroll-view class="sort-list" scroll-y>
        <view wx:for="{{sortedItems}}" wx:key="_id" class="sort-item pressable" data-index="{{index}}" bindtap="onTapDistanceItem">
          <view class="sort-rank">{{index + 1}}</view>
          <view class="sort-info">
            <view class="sort-title ellipsis">{{item.item.title}}</view>
            <view class="sort-meta">{{item.catLabel}}{{item._stars ? ' · ' + item._stars : ''}}</view>
          </view>
          <view class="sort-dist">{{item.distanceText}}</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showDetailCard}}" class="map-detail-card safe-area-bottom">
    <view class="map-detail-header">
      <image src="{{selectedItem.coverImage || '/images/default-cover.png'}}" class="map-detail-cover" mode="aspectFill"/>
      <view class="map-detail-close pressable" bindtap="onCloseCard">
        <lucide-icon name="x" size="28" color="#fff" />
      </view>
    </view>
    <view class="map-detail-body">
      <view class="map-detail-title">{{selectedItem.title}}</view>
      <view wx:if="{{selectedDistance}}" class="map-detail-distance">
        <lucide-icon name="navigation" size="20" color="#E8876A" />
        <text>距你 {{selectedDistance}}</text>
      </view>
      <view class="map-detail-cat">{{selectedCategoryLabel || selectedItem.category}}</view>
    </view>
    <view class="map-detail-action pressable" bindtap="onViewDetail">查看详情 →</view>
  </view>
</view>
