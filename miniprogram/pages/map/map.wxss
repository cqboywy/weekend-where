.map-page { position: relative; height: 100vh; }
.map-container { width: 100%; height: 100%; }

.map-filter-bar { position: absolute; top: 24rpx; left: 24rpx; right: 24rpx; z-index: 10; }
.map-filter-scroll {
  background: rgba(255,255,255,0.92); border-radius: var(--radius-full);
  padding: 8rpx 24rpx; box-shadow: var(--shadow-elevated); backdrop-filter: blur(8px);
}
.filter-row {
  display: inline-flex; white-space: nowrap; flex-wrap: nowrap; align-items: center;
}
.mode-chip {
  display: inline-block; padding: 10rpx 22rpx; border-radius: var(--radius-full);
  font-size: var(--text-sm); color: var(--color-primary); font-weight: 700;
  margin-right: 8rpx; background: var(--color-primary-soft);
}
.map-chip {
  display: inline-block; padding: 10rpx 22rpx; border-radius: var(--radius-full);
  font-size: var(--text-sm); color: var(--color-muted); margin-right: 8rpx;
  font-weight: 500; transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); line-height: 1.4;
}
.map-chip.active {
  background: var(--color-primary); color: #fff; font-weight: 600;
  box-shadow: var(--shadow-button);
}

/* Distance sort button */
.sort-btn {
  position: absolute; left: 120rpx; right: 120rpx; bottom: 280rpx;
  height: 88rpx; padding: 0 28rpx;
  background: linear-gradient(135deg, #E8876A, #F0A050);
  border-radius: var(--radius-xl);
  display: flex; align-items: center; gap: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(232,135,106,0.35); z-index: 10;
  font-size: var(--text-md); color: #fff; font-weight: 700;
}
.sort-btn-badge {
  margin-left: auto;
  font-size: var(--text-xs); font-weight: 400;
  opacity: 0.8; background: rgba(255,255,255,0.2);
  padding: 4rpx 16rpx; border-radius: var(--radius-full);
}

/* Distance sort bottom sheet */
.sort-overlay {
  position: absolute; inset: 0; z-index: 30;
  background: rgba(0,0,0,0.3);
  display: flex; align-items: flex-end;
}
.sort-sheet {
  width: 100%; max-height: 60vh;
  background: var(--color-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  display: flex; flex-direction: column;
  animation: fadeInUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.sort-sheet-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 28rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
  font-size: var(--text-md); font-weight: 700;
}
.sort-list { height: 600rpx; }
.sort-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.sort-item:active { background: var(--color-surface); }
.sort-rank {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--text-sm); font-weight: 700;
  color: var(--color-primary); background: var(--color-primary-soft);
  flex-shrink: 0;
}
.sort-info { flex: 1; overflow: hidden; }
.sort-title { font-size: var(--text-sm); font-weight: 600; color: var(--color-text); }
.sort-meta { font-size: var(--text-xs); color: var(--color-muted); margin-top: 4rpx; }
.sort-dist { font-size: var(--text-sm); color: var(--color-primary); font-weight: 600; flex-shrink: 0; }

.locate-btn {
  position: absolute; right: 24rpx; bottom: 280rpx;
  width: 88rpx; height: 88rpx; background: var(--color-white);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-float); z-index: 10;
}

.map-detail-card {
  position: absolute; bottom: 16rpx; left: 16rpx; right: 16rpx;
  background: var(--color-white); border-radius: var(--radius-xl);
  box-shadow: var(--shadow-float); z-index: 20;
  animation: fadeInUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.map-detail-header { position: relative; }
.map-detail-cover { width: 100%; height: 240rpx; border-radius: var(--radius-xl) var(--radius-xl) 0 0; }
.map-detail-close {
  position: absolute; top: 16rpx; right: 16rpx; width: 52rpx; height: 52rpx;
  background: rgba(30,22,12,0.45); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.map-detail-body { padding: 28rpx; }
.map-detail-title { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; line-height: var(--leading-tight); }
.map-detail-distance {
  display: flex; align-items: center; gap: 6rpx;
  margin-top: 10rpx;
  font-size: var(--text-sm); color: var(--color-primary); font-weight: 500;
}
.map-detail-cat { font-size: var(--text-sm); color: var(--color-muted); margin-top: 8rpx; }
.map-detail-action {
  padding: 22rpx 28rpx; border-top: 1rpx solid var(--color-border);
  text-align: center; font-size: var(--text-base); color: var(--color-primary); font-weight: 700;
}
