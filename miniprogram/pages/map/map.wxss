.map-page { position: relative; height: 100vh; }
.map-container { width: 100%; height: 100%; }

.map-filter-bar { position: absolute; top: 20rpx; left: 20rpx; right: 20rpx; z-index: 10; }
.map-filter-scroll {
  white-space: nowrap; background: rgba(255,255,255,0.95);
  border-radius: var(--radius-full); padding: 6rpx 12rpx;
  box-shadow: var(--shadow-elevated); backdrop-filter: blur(10px);
}
.map-chip {
  display: inline-block; padding: 8rpx 20rpx; border-radius: var(--radius-full);
  font-size: var(--text-sm); color: var(--color-text-secondary); margin-right: 6rpx;
  font-weight: 500; transition: all 0.2s; line-height: 1.4;
}
.map-chip:active { transform: scale(0.95); }
.map-chip.active { background: var(--color-primary); color: #fff; font-weight: 600; }

.locate-btn {
  position: absolute; right: 20rpx; bottom: 260rpx;
  width: 80rpx; height: 80rpx; background: var(--color-white);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-elevated); z-index: 10;
}
.locate-btn:active { transform: scale(0.92); }
.locate-icon { font-size: 40rpx; }

.map-detail-card {
  position: absolute; bottom: 0; left: 12rpx; right: 12rpx;
  background: var(--color-white); border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  box-shadow: var(--shadow-float); z-index: 20;
}
.map-detail-header { position: relative; }
.map-detail-cover { width: 100%; height: 220rpx; border-radius: var(--radius-xl) var(--radius-xl) 0 0; }
.map-detail-close {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 52rpx; height: 52rpx; background: rgba(0,0,0,0.45); color: #fff;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 300;
}
.map-detail-body { padding: 24rpx; }
.map-detail-title { font-size: var(--text-lg); font-weight: 700; line-height: var(--leading-tight); }
.map-detail-cat { font-size: var(--text-sm); color: var(--color-text-secondary); margin-top: 6rpx; }
.map-detail-action {
  padding: 18rpx 24rpx; border-top: 1rpx solid var(--color-border);
  text-align: center; font-size: var(--text-base); color: var(--color-primary); font-weight: 700;
}
