/* =============================================
   周末去哪儿 — Peach & Honey v5
   UI-UX-Pro-Max · Warm Pet-Grooming Inspired
   ============================================= */

page {
  /* —— Color Tokens —— */
  --color-bg: #FFFFFF;
  --color-text: #3D2B1F;
  --color-primary: #E8876A;
  --color-primary-soft: #FFF0E8;
  --color-surface: #FFF3EB;
  --color-border: #F2E2D5;
  --color-accent: #F0A050;
  --color-accent-soft: #FFF6ED;
  --color-white: #FFFFFF;
  --color-success: #7CB889;
  --color-danger: #D4735E;
  --color-muted: #B8A89A;

  /* —— Radius —— */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 36rpx;
  --radius-xl: 48rpx;
  --radius-full: 9999rpx;
  --radius-arch: 240rpx;

  /* —— Shadows (warm-tinted, soft) —— */
  --shadow-card: 0 4rpx 16rpx rgba(61, 43, 31, 0.06);
  --shadow-elevated: 0 8rpx 32rpx rgba(61, 43, 31, 0.08);
  --shadow-float: 0 16rpx 48rpx rgba(61, 43, 31, 0.10);
  --shadow-button: 0 4rpx 16rpx rgba(232, 135, 106, 0.30);

  /* —— Type Scale —— */
  --text-xs: 20rpx;
  --text-sm: 24rpx;
  --text-base: 28rpx;
  --text-md: 32rpx;
  --text-lg: 38rpx;
  --text-xl: 48rpx;
  --text-2xl: 64rpx;
  --text-3xl: 80rpx;

  /* —— Leading & Tracking —— */
  --leading-tight: 1.15;
  --leading-normal: 1.5;
  --leading-relaxed: 1.75;
  --tracking-tight: -0.5rpx;
  --tracking-normal: 0;
  --tracking-wide: 1rpx;
  --tracking-widest: 2rpx;

  /* —— Fonts —— */
  --font-heading: "Playfair Display", Georgia, "Times New Roman", serif;
  --font-body: "Source Sans 3", "PingFang SC", "Microsoft YaHei", -apple-system, sans-serif;

  /* —— Base —— */
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  -webkit-font-smoothing: antialiased;
}

/* —— Layout —— */
.page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* —— Safe Areas —— */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* —— Text Utilities —— */
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }

/* —— Card Base —— */
.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.card-surface {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
}
.card-elevated {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-elevated);
}

/* —— Tags —— */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: var(--tracking-wide);
}
.tag-primary {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}
.tag-accent {
  background: var(--color-accent-soft);
  color: var(--color-accent);
}

/* —— Separator —— */
.separator {
  height: 1rpx;
  background: var(--color-border);
}

/* —— Image default bg —— */
/* removed — was bleeding under lucide-icon components */

/* —— Animations —— */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(32rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes floatIn {
  from { opacity: 0; transform: translateY(64rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes popIn {
  0% { opacity: 0; transform: scale(0.8); }
  60% { transform: scale(1.04); }
  100% { opacity: 1; transform: scale(1); }
}
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.page {
  animation: fadeIn 0.4s ease-out;
}
.fade-in-up {
  animation: fadeInUp 0.5s cubic-bezier(0.32, 0.72, 0, 1) both;
}
.float-in {
  animation: floatIn 0.6s cubic-bezier(0.32, 0.72, 0, 1) both;
}
.pop-in {
  animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

/* —— Staggered entry delays —— */
.stagger-1 { animation-delay: 0.05s; }
.stagger-2 { animation-delay: 0.10s; }
.stagger-3 { animation-delay: 0.15s; }
.stagger-4 { animation-delay: 0.20s; }
.stagger-5 { animation-delay: 0.25s; }

/* —— Press feedback —— */
.pressable { transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease; }
.pressable:active { transform: scale(0.97); }
