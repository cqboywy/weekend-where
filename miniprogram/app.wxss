/* =============================================
   周末去哪儿 — Editorial Journal v6
   Refined serif + warm paper + rust accent
   ============================================= */

page {
  /* —— Color Tokens —— */
  --color-bg: #FAF8F5;
  --color-text: #2C2416;
  --color-primary: #C2674A;
  --color-primary-soft: #F5EDE6;
  --color-surface: #F3EFEA;
  --color-border: #E8E2D8;
  --color-accent: #B88A5C;
  --color-accent-soft: #F4EDE3;
  --color-white: #FFFFFF;
  --color-success: #7C9A7E;
  --color-danger: #C46A5A;
  --color-muted: #9E9688;

  /* —— Radius —— */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-full: 9999rpx;

  /* —— Shadows (warm, muted) —— */
  --shadow-card: 0 2rpx 12rpx rgba(44,36,22,0.04);
  --shadow-elevated: 0 4rpx 20rpx rgba(44,36,22,0.06);
  --shadow-float: 0 8rpx 32rpx rgba(44,36,22,0.08);
  --shadow-button: 0 2rpx 10rpx rgba(194,103,74,0.18);

  /* —— Type Scale —— */
  --text-xs: 20rpx;
  --text-sm: 24rpx;
  --text-base: 28rpx;
  --text-md: 32rpx;
  --text-lg: 40rpx;
  --text-xl: 52rpx;
  --text-2xl: 68rpx;
  --text-3xl: 84rpx;

  /* —— Leading & Tracking —— */
  --leading-tight: 1.15;
  --leading-normal: 1.6;
  --leading-relaxed: 1.8;
  --tracking-tight: -0.5rpx;
  --tracking-normal: 0;
  --tracking-wide: 1rpx;
  --tracking-widest: 3rpx;

  /* —— Fonts —— */
  --font-heading: "Noto Serif SC", "Source Han Serif SC", "Songti SC", Georgia, serif;
  --font-body: "Noto Sans SC", "Source Han Sans SC", "PingFang SC", "Microsoft YaHei", -apple-system, sans-serif;

  /* —— Base —— */
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  -webkit-font-smoothing: antialiased;
}

/* —— Layout —— */
.page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* —— Safe Areas —— */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* —— Text Utilities —— */
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }

/* —— Card Base —— */
.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.card-surface {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
}
.card-elevated {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-elevated);
}

/* —— Tags —— */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: var(--tracking-wide);
}
.tag-primary {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}
.tag-accent {
  background: var(--color-accent-soft);
  color: var(--color-accent);
}

/* —— Separator —— */
.separator {
  height: 1rpx;
  background: var(--color-border);
}

/* —— Animations —— */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(32rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes floatIn {
  from { opacity: 0; transform: translateY(64rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes popIn {
  0% { opacity: 0; transform: scale(0.8); }
  60% { transform: scale(1.04); }
  100% { opacity: 1; transform: scale(1); }
}
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.page {
  animation: fadeIn 0.4s ease-out;
}
.fade-in-up {
  animation: fadeInUp 0.5s cubic-bezier(0.32, 0.72, 0, 1) both;
}
.float-in {
  animation: floatIn 0.6s cubic-bezier(0.32, 0.72, 0, 1) both;
}
.pop-in {
  animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

/* —— Staggered entry delays —— */
.stagger-1 { animation-delay: 0.05s; }
.stagger-2 { animation-delay: 0.10s; }
.stagger-3 { animation-delay: 0.15s; }
.stagger-4 { animation-delay: 0.20s; }
.stagger-5 { animation-delay: 0.25s; }

/* —— Press feedback —— */
.pressable { transition: transform 0.2s cubic-bezier(0.32, 0.72, 0, 1), box-shadow 0.3s ease; }
.pressable:active { transform: scale(0.97); }

/* —— Outline button (editorial style) —— */
.btn-outline {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 16rpx 36rpx; border-radius: var(--radius-full);
  border: 1.5px solid var(--color-border);
  background: transparent; color: var(--color-text);
  font-size: var(--text-sm); font-weight: 500;
  line-height: 1.4;
}
.btn-outline:active { background: var(--color-surface); }
