/* =============================================
   周末去哪儿 — Botanical / Organic Serif v4
   ============================================= */

page {
  /* —— Color Tokens —— */
  --color-bg: #F9F8F4;
  --color-text: #2D3A31;
  --color-primary: #8C9A84;
  --color-surface: #DCCFC2;
  --color-border: #E6E2DA;
  --color-accent: #C27B66;
  --color-white: #FFFFFF;

  /* —— Radius —— */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-full: 9999rpx;
  --radius-arch: 200rpx;

  /* —— Shadows (forest-green tinted, very soft) —— */
  --shadow-card: 0 4rpx 6rpx -1rpx rgba(45, 58, 49, 0.04);
  --shadow-elevated: 0 10rpx 15rpx -3rpx rgba(45, 58, 49, 0.05);
  --shadow-float: 0 20rpx 40rpx -10rpx rgba(45, 58, 49, 0.05);

  /* —— Type Scale —— */
  --text-xs: 20rpx;
  --text-sm: 24rpx;
  --text-base: 28rpx;
  --text-md: 32rpx;
  --text-lg: 38rpx;
  --text-xl: 48rpx;
  --text-2xl: 64rpx;
  --text-3xl: 80rpx;

  /* —— Leading & Tracking —— */
  --leading-tight: 1.15;
  --leading-normal: 1.5;
  --leading-relaxed: 1.75;
  --tracking-tight: -0.5rpx;
  --tracking-normal: 0;
  --tracking-wide: 1rpx;
  --tracking-widest: 2rpx;

  /* —— Fonts —— */
  --font-heading: "Playfair Display", Georgia, "Times New Roman", serif;
  --font-body: "Source Sans 3", "PingFang SC", "Microsoft YaHei", -apple-system, sans-serif;

  /* —— Base —— */
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  -webkit-font-smoothing: antialiased;

  /* —— TEXTURE (soul of the design) —— */
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.015'/%3E%3C/svg%3E");
  background-repeat: repeat;
}

/* —— Layout —— */
.page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* —— Safe Areas —— */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* —— Text Utilities —— */
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }

/* —— Card Base —— */
.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.card-surface {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
}
.card-elevated {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-elevated);
}

/* —— Tags —— */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
}
.tag-primary {
  background: rgba(140, 154, 132, 0.15);
  color: var(--color-primary);
}
.tag-accent {
  background: rgba(194, 123, 102, 0.12);
  color: var(--color-accent);
}

/* —— Separator —— */
.separator {
  height: 1rpx;
  background: var(--color-border);
}

/* —— Image default bg —— */
image {
  background: var(--color-surface);
}

/* —— Animations —— */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(32rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.96); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes floatIn {
  from { opacity: 0; transform: translateY(48rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.page {
  animation: fadeIn 0.5s ease-out;
}
.fade-in-up {
  animation: fadeInUp 0.6s ease-out both;
}
.float-in {
  animation: floatIn 0.7s ease-out both;
}
